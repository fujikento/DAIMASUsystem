# イマーシブダイニング プロジェクション体験システム
# 環境変数設定ファイル（.env にコピーして使用）

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./immersive_dining.db

# === TouchDesigner OSC ===
TD_OSC_HOST=127.0.0.1
TD_OSC_PORT=7000

# === AI Image & Video Generation (Google) ===
# Gemini / Imagen (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# === AI Image & Video Generation (fal.ai) ===
# fal.ai — Flux Pro (image) & Kling Video (video)
# https://fal.ai/dashboard/keys
FAL_API_KEY=96f06d23-b22a-4e0c-a17e-8dd3bfcda917:0725ebae9cf6b4f95ef36f0b51b92df7

# === AI Video Generation ===
# Runway Gen-4.5 (https://dev.runwayml.com)
RUNWAY_API_KEY=

# Kling 2.6 (https://klingai.com)
KLING_API_KEY=

# === Photo Animation ===
# LivePortrait (ローカル実行 - GitHubからクローン)
LIVEPORTRAIT_PATH=/Users/kento/LivePortrait

# Hedra AI (https://hedra.com)
HEDRA_API_KEY=

# === File Storage ===
UPLOAD_DIR=./api/uploads
CONTENT_DIR=./touchdesigner/content
